---
import BaseHead from '../components/BaseHead.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';
import memoriesData from '../data/memories.json';

interface Memory {
	image: string;
	date: string;
	title: string;
	description?: string;
}

// 按日期倒序——新的在前
const memories: Memory[] = [...(memoriesData as Memory[])].sort(
	(a, b) => new Date(b.date).getTime() - new Date(a.date).getTime(),
);
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={`回忆 · ${SITE_TITLE}`} description="一些不想被时间冲走的瞬间" />
	</head>
	<body>
		<Header />
		<main>
			<h1>回忆</h1>
			<p class="hint">「此后，将有百花绽放，因为我从未离去」——一些不想被时间冲走的瞬间。</p>

			{
				memories.length === 0 ? (
					<p class="empty">还没有回忆。等你把第一张照片放进来吧 ✨</p>
				) : (
					<ul class="memory-grid">
						{memories.map((m) => (
							<li class="memory-card">
								<a href={m.image} target="_blank" rel="noopener" class="memory-img-wrap">
									<img src={m.image} alt={m.title} loading="lazy" />
								</a>
								<div class="memory-info">
									<div class="memory-date">
										<FormattedDate date={new Date(m.date)} />
									</div>
									<h3 class="memory-title">{m.title}</h3>
									{m.description && <p class="memory-desc">{m.description}</p>}
								</div>
							</li>
						))}
					</ul>
				)
			}
		</main>
		<Footer />

		<style>
			main {
				width: min(1080px, 100% - 2em);
			}
			h1 {
				margin-bottom: 0.2em;
			}
			.hint {
				color: rgb(var(--gray));
				margin-bottom: 1.5em;
			}
			.empty {
				text-align: center;
				color: rgb(var(--gray));
				padding: 2.5em;
				background: rgba(255, 255, 255, 0.45);
				border: 1px dashed rgba(0, 0, 0, 0.1);
				border-radius: 14px;
			}

			.memory-grid {
				list-style: none;
				padding: 0;
				margin: 0;
				display: grid;
				grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
				gap: 1.2em;
			}
			.memory-card {
				display: flex;
				flex-direction: column;
				background: rgba(255, 255, 255, 0.55);
				backdrop-filter: blur(18px) saturate(180%);
				-webkit-backdrop-filter: blur(18px) saturate(180%);
				border: 1px solid rgba(255, 255, 255, 0.45);
				border-radius: 14px;
				overflow: hidden;
				box-shadow: 0 8px 24px rgba(31, 38, 135, 0.12);
				transition: transform 0.2s ease, box-shadow 0.2s ease;
			}
			.memory-card:hover {
				transform: translateY(-4px);
				box-shadow: 0 14px 36px rgba(31, 38, 135, 0.18);
			}
			.memory-img-wrap {
				display: block;
				width: 100%;
				aspect-ratio: 4 / 3;
				background: rgba(0, 0, 0, 0.05);
				overflow: hidden;
			}
			.memory-img-wrap img {
				display: block;
				width: 100%;
				height: 100%;
				object-fit: cover;
				transition: transform 0.4s ease;
			}
			.memory-card:hover .memory-img-wrap img {
				transform: scale(1.04);
			}
			.memory-info {
				padding: 0.9em 1em 1.1em;
			}
			.memory-date {
				font-size: 0.78em;
				color: rgb(var(--gray));
				letter-spacing: 0.04em;
				margin-bottom: 0.35em;
			}
			.memory-title {
				margin: 0 0 0.3em;
				font-size: 1.05em;
				color: rgb(var(--gray-dark));
				line-height: 1.4;
			}
			.memory-desc {
				margin: 0;
				font-size: 0.85em;
				color: rgb(var(--gray));
				line-height: 1.5;
			}

			@media (max-width: 640px) {
				.memory-grid {
					grid-template-columns: 1fr;
					gap: 1em;
				}
			}
			@media (prefers-reduced-motion: reduce) {
				.memory-card,
				.memory-img-wrap img {
					transition: none;
				}
				.memory-card:hover .memory-img-wrap img {
					transform: none;
				}
			}
		</style>
	</body>
</html>
