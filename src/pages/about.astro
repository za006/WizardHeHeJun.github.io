---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import elysia from '../assets/elysia.png';
import BaseHead from '../components/BaseHead.astro';
import Comments from '../components/Comments.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';

const posts = await getCollection('blog');
const categoryCount = new Set(posts.map((p) => p.data.category)).size;
const tagCount = new Set(posts.flatMap((p) => p.data.tags)).size;

// 主要项目高亮（手动挑对应博文 slug）
const featured = [
	{ slug: 'kng', emoji: '🧠', name: 'KNG', desc: '让 Claude Code 越用越准的知识驱动框架' },
	{ slug: 'lacuna', emoji: '📖', name: 'Lacuna', desc: '半生成式叙事引擎——作者写骨架，LLM 填留白' },
];

// 身份标签云（不是技能，是自我认同）
const identity = [
	'🧪 QA 工程师',
	'🤖 AI 应用开发者',
	'🌸 爱莉希雅厨',
	'🎮 ACGN 狂热爱好者',
	'⚡ Claude Code 重度用户',
	'📷 电子爱好者',
	'🌙 深夜 debug 选手',
	'🔧 折腾控',
	'☕ 一杯咖啡能熬到凌晨',
];


// 工具箱分类
const stack = [
	{ name: '语言', items: ['Python', 'C#','C/C++'] },
	{ name: '测试自动化', items: ['Selenium', 'pytest'] },
	{ name: ' 机器学习', items: ['PyTorch','transformer','CUDA','OpenCV'] },
];
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={`关于 · ${SITE_TITLE}`} description="WizardHeHeJun 的自我介绍" />
	</head>
	<body>
		<Header />
		<main>
			<!-- ━━━━━━━━━━ Hero ━━━━━━━━━━ -->
			<section class="hero">
				<Image src={elysia} width={140} height={140} alt="头像" class="avatar" />
				<h1 class="name">WizardHeHeJun</h1>
				<p class="romaji">WizardryLaw_呵呵君HJ</p>

				<div class="pills">
					<span class="pill">🤖 AI 工程师</span>
					<span class="pill">🧪 测试自动化</span>
					<span class="pill">🎮 游戏开发</span>
					<span class="pill">✨ ACG 爱好者</span>
				</div>

				<div class="socials">
					<a href="https://github.com/WizardHeHeJun" target="_blank" rel="noopener" aria-label="GitHub">
						<svg viewBox="0 0 16 16" aria-hidden="true" width="22" height="22"
							><path
								fill="currentColor"
								d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"
							></path></svg
						>
					</a>
					<a href="https://space.bilibili.com/40752109" target="_blank" rel="noopener" aria-label="哔哩哔哩">
						<svg viewBox="0 0 1024 1024" aria-hidden="true" width="22" height="22"
							><path
								fill="currentColor"
								d="M306.005 117.632 444.331 256h135.296l138.368-138.325a42.667 42.667 0 0 1 60.373 60.373L700.331 256H789.333A149.333 149.333 0 0 1 938.667 405.333v341.334a149.333 149.333 0 0 1-149.334 149.333H234.667A149.333 149.333 0 0 1 85.333 746.667V405.333A149.333 149.333 0 0 1 234.667 256h88.96L245.632 177.963a42.667 42.667 0 0 1 60.373-60.331zM789.333 341.333H234.667a64 64 0 0 0-63.702 57.856L170.667 405.333v341.334a64 64 0 0 0 57.856 63.701l6.144.299h554.666a64 64 0 0 0 63.702-57.856l.299-6.144V405.333a64 64 0 0 0-64-64zM341.333 469.333a42.667 42.667 0 0 1 42.667 42.667v42.667a42.667 42.667 0 0 1-85.333 0V512a42.667 42.667 0 0 1 42.666-42.667zm341.334 0a42.667 42.667 0 0 1 42.666 42.667v42.667a42.667 42.667 0 0 1-85.333 0V512a42.667 42.667 0 0 1 42.667-42.667z"
							></path></svg
						>
					</a>
					<a href="https://x.com/wizardhehejun" target="_blank" rel="noopener" aria-label="X (Twitter)">
						<svg viewBox="0 0 16 16" aria-hidden="true" width="22" height="22"
							><path
								fill="currentColor"
								d="M12.6.75h2.454l-5.36 6.142L16 15.25h-4.937l-3.867-5.07-4.425 5.07H.316l5.733-6.57L0 .75h5.063l3.495 4.633L12.601.75Zm-.86 13.028h1.36L4.323 2.145H2.865z"
							></path></svg
						>
					</a>
					<a href="mailto:1617186107@qq.com" aria-label="发邮件给我">
						<svg viewBox="0 0 24 24" aria-hidden="true" width="22" height="22"
							><path
								fill="currentColor"
								d="M20 4H4a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V6a2 2 0 0 0-2-2zm0 4.236-8 4.882-8-4.882V6l8 4.882L20 6v2.236z"
							></path></svg
						>
					</a>
				</div>

				<div class="stats">
					<div><b>{posts.length}</b><span>文章</span></div>
					<div><b>{categoryCount}</b><span>分类</span></div>
					<div><b>{tagCount}</b><span>标签</span></div>
				</div>
			</section>

			<!-- ━━━━━━━━━━ 自我介绍 ━━━━━━━━━━ -->
			<section class="card">
				<h2>👋 你好</h2>
				<p>
					我是 <strong>呵呵君HJ</strong>，本职是某游戏厂的<strong>测试工程师</strong>。
					工作里跟 bug、自动化测试、agent开发打交道；下班后折腾ACGN相关（看番、游戏）
					和一些不怎么实用但有意思的小项目。现在主攻是agent开发以及机器学习算法研究，目标是把 AI 训成自己的副驾驶，帮我写代码、做设计、规划日常，甚至一起玩游戏（虽然现在还不太行）。
					也是一个电子爱好者，平时也会折腾一些电子小玩具（最近在玩树莓派和 esp32），偶尔会写写技术笔记，但更多时候是「写完了再说」。
					爱莉希雅和洛天依本命。
					写代码必须有 BGM，喜欢 ACG / Hi-Fi。
					总之就是个对很多东西都感兴趣、喜欢折腾的人吧～
				</p>
				<p>
					这个博客是我的「数字背包」——装着写过的代码、想通的事，还有一些不想被时间冲走的碎碎念。
				</p>
				<p>
					如果你恰好读到对你有用的内容，那就是写这些字最满意的回报啦——
					<em>「不是吗？」</em>
				</p>
			</section>

			<!-- ━━━━━━━━━━ 身份标签云 ━━━━━━━━━━ -->
			<section class="card identity-card">
				<details open class="identity-toggle">
					<summary>
						<span class="toggle-arrow">▼</span>
						<span>我给自己贴的标签</span>
					</summary>
					<div class="identity-tags">
						{identity.map((t, i) => <span class={`id-tag id-tag-${i % 8}`}>{t}</span>)}
					</div>
				</details>
			</section>

			<!-- ━━━━━━━━━━ 工具箱 ━━━━━━━━━━ -->
			<section class="card">
				<h2>🛠️ 工具箱</h2>
				<p class="muted">日常用得多、真正能写出东西的。</p>
				<div class="stack">
					{
						stack.map((g) => (
							<div class="stack-row">
								<div class="stack-label">{g.name}</div>
								<div class="stack-chips">
									{g.items.map((it) => (
										<span class="chip">{it}</span>
									))}
								</div>
							</div>
						))
					}
				</div>
			</section>

			<!-- ━━━━━━━━━━ 主要项目 ━━━━━━━━━━ -->
			<section class="card">
				<h2>🌟 主要项目</h2>
				<p class="muted">挑了 3 个开源的代表作，详细介绍各自有博文。</p>
				<div class="proj-grid">
					{
						featured.map((p) => (
							<a class="proj" href={`/blog/${p.slug}/`}>
								<div class="proj-emoji">{p.emoji}</div>
								<div class="proj-name">{p.name}</div>
								<div class="proj-desc">{p.desc}</div>
							</a>
						))
					}
				</div>
				<p class="more-link">
					<a href="/blog/">看所有文章 →</a>
				</p>
			</section>

			<!-- ━━━━━━━━━━ 日常碎碎念 ━━━━━━━━━━ -->
			<section class="card">
				<h2>🎮 日常碎碎念</h2>
				<ul class="facts">
					<li>🐛 工作上跟 bug 斗智斗勇——「修不完，根本修不完」</li>
					<li>🤖 业余沉迷 Claude Code + Agent 框架，把 AI 训成自己的副驾驶</li>
					<li>🌸 米哈游精神股东：崩坏 3 老玩家，爱莉希雅本命（看头像）</li>
					<li>🎵 写代码必须有 BGM，喜欢 ACG / Lo-Fi</li>
					<li>📚 偶尔写写技术笔记，但更多时候是「写完了再说」</li>
					<li>☕ 一杯咖啡能熬到凌晨，第二天起床后悔</li>
				</ul>
			</section>

			<!-- ━━━━━━━━━━ 关于这个站 ━━━━━━━━━━ -->
			<section class="card">
				<h2>🏠 关于这个站</h2>
				<ul class="meta-list">
					<li>
						<b>构建</b>：<code>Astro 6</code> + <code>GitHub Pages</code> +
						<code>GitHub Actions</code> 自动部署
					</li>
					<li>
						<b>主题</b>：自己手搓的毛玻璃风（<code>backdrop-filter</code> + 渐变 +
						海边小姐姐背景图）
					</li>
					<li>
						<b>字体</b>：霞鹜文楷（LXGW WenKai Screen），通过 jsDelivr CDN 按字符 chunk 加载
					</li>
					<li><b>搜索</b>：Pagefind 静态全文索引——零运维</li>
					<li><b>音乐</b>：APlayer + MetingJS，默认 ACG 公共歌单</li>
					<li>
						<b>开源</b>：完整代码在
						<a href="https://github.com/WizardHeHeJun/WizardHeHeJun.github.io" target="_blank">
							GitHub
						</a>，欢迎 fork
					</li>
				</ul>
				<p class="more-link">
					<a href="/blog/building-this-blog/">完整搭建过程 →</a>
				</p>
			</section>

			<!-- ━━━━━━━━━━ 评论 & 表情 ━━━━━━━━━━ -->
			<Comments
				mapping="specific"
				term="page-about"
				title="💬 来这里找我聊聊吧～"
				hint="读完了？那就别走得这么悄无声息嘛——留个表情或写两句，「悄悄告诉你哦，我每条都会看的呢」"
			/>
		</main>
		<Footer />

		<style>
			main {
				width: min(800px, 100% - 2em);
				background: transparent;
				backdrop-filter: none;
				-webkit-backdrop-filter: none;
				border: none;
				border-radius: 0;
				box-shadow: none;
				padding: 1em;
				display: flex;
				flex-direction: column;
				gap: 1.2em;
			}

			/* —— Hero —— */
			.hero {
				text-align: center;
				padding: 2.2em 1.6em;
				background: rgba(255, 255, 255, 0.55);
				backdrop-filter: blur(18px) saturate(180%);
				-webkit-backdrop-filter: blur(18px) saturate(180%);
				border: 1px solid rgba(255, 255, 255, 0.45);
				border-radius: 18px;
				box-shadow: 0 8px 32px rgba(31, 38, 135, 0.15);
			}
			.avatar {
				display: block;
				margin: 0 auto 0.6em;
				width: 110px;
				height: 110px;
				border-radius: 50%;
				object-fit: cover;
				border: 4px solid rgba(255, 255, 255, 0.7);
				box-shadow:
					0 0 0 4px rgba(194, 128, 255, 0.2),
					0 8px 24px rgba(31, 38, 135, 0.18);
				cursor: pointer;
				will-change: transform;
			}
			.avatar:hover {
				animation: avatar-wiggle 0.6s cubic-bezier(0.36, 0, 0.45, 1.4);
			}
			@media (prefers-reduced-motion: reduce) {
				.avatar:hover {
					animation: none;
				}
			}
			.name {
				font-size: clamp(1.6em, 3vw + 1em, 2.4em);
				margin: 0.2em 0 0;
				font-weight: 800;
				color: rgb(var(--gray-dark));
			}
			.romaji {
				margin: 0.1em 0 1em;
				color: rgb(var(--gray));
				letter-spacing: 0.08em;
				font-size: 0.95em;
			}
			.pills {
				display: flex;
				justify-content: center;
				flex-wrap: wrap;
				gap: 0.5em;
				margin-bottom: 1em;
			}
			.pill {
				display: inline-block;
				padding: 0.3em 0.9em;
				background: rgba(255, 255, 255, 0.7);
				border: 1px solid rgba(255, 255, 255, 0.8);
				border-radius: 999px;
				font-size: 0.85em;
				color: rgb(var(--gray-dark));
			}
			.socials {
				display: flex;
				justify-content: center;
				gap: 0.6em;
				margin-bottom: 1.2em;
				flex-wrap: wrap;
			}
			.socials a {
				display: inline-flex;
				align-items: center;
				justify-content: center;
				width: 40px;
				height: 40px;
				background: rgba(0, 0, 0, 0.04);
				color: rgb(var(--gray));
				text-decoration: none;
				border-radius: 50%;
				transition: background 0.15s ease, color 0.15s ease, transform 0.15s ease;
			}
			.socials a:hover {
				background: rgba(35, 55, 255, 0.1);
				color: var(--accent);
				transform: translateY(-2px);
			}
			.socials svg {
				display: block;
				width: 22px;
				height: 22px;
			}
			.stats {
				display: flex;
				justify-content: center;
				gap: 2em;
				padding-top: 1em;
				border-top: 1px dashed rgba(0, 0, 0, 0.08);
			}
			.stats div {
				display: flex;
				flex-direction: column;
				align-items: center;
			}
			.stats b {
				font-size: 1.6em;
				font-weight: 700;
				color: var(--accent);
				line-height: 1;
			}
			.stats span {
				font-size: 0.78em;
				color: rgb(var(--gray));
				margin-top: 0.3em;
			}

			/* —— 通用 card —— */
			.card {
				padding: 1.6em 1.8em;
				background: rgba(255, 255, 255, 0.5);
				backdrop-filter: blur(16px) saturate(170%);
				-webkit-backdrop-filter: blur(16px) saturate(170%);
				border: 1px solid rgba(255, 255, 255, 0.45);
				border-radius: 18px;
				box-shadow: 0 8px 32px rgba(31, 38, 135, 0.12);
			}
			.card h2 {
				margin: 0 0 0.6em;
				font-size: 1.4em;
			}
			.card p {
				margin: 0.5em 0;
				line-height: 1.7;
			}
			.muted {
				color: rgb(var(--gray));
				font-size: 0.9em;
			}

			/* —— 身份标签云（粉色折叠条 + 彩色纯文本标签）—— */
			.identity-card {
				padding: 0.6em 0.8em;
			}
			.identity-toggle {
				margin: 0;
			}
			.identity-toggle > summary {
				list-style: none;
				cursor: pointer;
				padding: 0.5em 0.9em;
				background: linear-gradient(
					90deg,
					rgba(255, 93, 143, 0.12),
					rgba(255, 93, 143, 0.04)
				);
				border-left: 3px solid rgba(255, 93, 143, 0.55);
				border-radius: 6px;
				font-weight: 600;
				color: rgb(var(--gray-dark));
				display: flex;
				align-items: center;
				gap: 0.5em;
				user-select: none;
			}
			.identity-toggle > summary::-webkit-details-marker {
				display: none;
			}
			.toggle-arrow {
				display: inline-block;
				font-size: 0.7em;
				color: rgba(255, 93, 143, 0.7);
				transition: transform 0.2s ease;
			}
			.identity-toggle:not([open]) .toggle-arrow {
				transform: rotate(-90deg);
			}
			.identity-tags {
				display: flex;
				flex-wrap: wrap;
				gap: 0.3em 0.9em;
				padding: 0.9em 1em 0.4em;
				line-height: 1.9;
				font-size: 0.95em;
			}
			.id-tag {
				display: inline;
				transition: opacity 0.15s ease;
			}
			.id-tag:hover {
				opacity: 0.7;
			}
			.id-tag-0 { color: #ff7e5f; }
			.id-tag-1 { color: #4a90e2; }
			.id-tag-2 { color: #5fb878; }
			.id-tag-3 { color: #ff5d8f; }
			.id-tag-4 { color: #3eb8b8; }
			.id-tag-5 { color: #a878e0; }
			.id-tag-6 { color: #f0a040; }
			.id-tag-7 { color: #4fb5d6; }

			/* —— 工具箱 —— */
			.stack {
				display: flex;
				flex-direction: column;
				gap: 0.6em;
				margin-top: 0.5em;
			}
			.stack-row {
				display: flex;
				gap: 0.8em;
				align-items: flex-start;
			}
			.stack-label {
				min-width: 6em;
				padding-top: 0.25em;
				color: rgb(var(--gray));
				font-size: 0.9em;
				flex-shrink: 0;
			}
			.stack-chips {
				display: flex;
				flex-wrap: wrap;
				gap: 0.4em;
			}
			.chip {
				display: inline-block;
				padding: 0.2em 0.7em;
				background: rgba(35, 55, 255, 0.07);
				border: 1px solid rgba(35, 55, 255, 0.15);
				border-radius: 6px;
				font-size: 0.85em;
				color: var(--accent);
			}

			/* —— 主要项目 —— */
			.proj-grid {
				display: grid;
				grid-template-columns: repeat(auto-fit, minmax(min(200px, 100%), 1fr));
				gap: 0.8em;
				margin-top: 0.5em;
			}
			.proj {
				display: flex;
				flex-direction: column;
				padding: 1em;
				background: rgba(255, 255, 255, 0.45);
				border: 1px solid rgba(255, 255, 255, 0.5);
				border-radius: 12px;
				color: rgb(var(--gray-dark));
				text-decoration: none;
				transition: transform 0.15s ease, background 0.15s ease;
			}
			.proj:hover {
				transform: translateY(-3px);
				background: rgba(255, 255, 255, 0.75);
			}
			.proj-emoji {
				font-size: 1.8em;
				margin-bottom: 0.2em;
			}
			.proj-name {
				font-weight: 700;
				font-size: 1.05em;
				color: var(--accent);
				margin-bottom: 0.3em;
			}
			.proj-desc {
				font-size: 0.85em;
				color: rgb(var(--gray));
				line-height: 1.5;
			}
			.more-link {
				margin-top: 1em !important;
				text-align: right;
			}
