---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={`搜索 · ${SITE_TITLE}`} description="搜索博客内容" />
	</head>
	<body>
		<Header />
		<main>
			<!-- 紧凑搜索框 -->
			<div class="search-bar">
				<input
					type="search"
					id="q"
					class="search-input"
					placeholder="搜索文章..."
					autocomplete="off"
				/>
				<button id="go" class="search-btn" type="button">搜索</button>
			</div>

			<p class="hint" id="hint">输入关键词即可。按 <kbd>/</kbd> 聚焦，<kbd>Esc</kbd> 清空。</p>

			<div id="results" class="results"></div>
		</main>
		<Footer />

		<script is:inline>
			let pagefind = null;
			let timer = null;

			const input = document.getElementById('q');
			const button = document.getElementById('go');
			const hint = document.getElementById('hint');
			const results = document.getElementById('results');

			async function ensureLoaded() {
				if (pagefind) return pagefind;
				pagefind = await import('/pagefind/pagefind.js');
				await pagefind.options({ excerptLength: 30 });
				await pagefind.init();
				return pagefind;
			}

			async function doSearch(q) {
				if (!q || !q.trim()) {
					results.innerHTML = '';
					hint.textContent = '输入关键词即可。按 / 聚焦，Esc 清空。';
					return;
				}
				hint.textContent = `正在搜索「${q}」...`;
				const pf = await ensureLoaded();
				const search = await pf.search(q);
				const items = await Promise.all(search.results.slice(0, 10).map((r) => r.data()));
				if (items.length === 0) {
					hint.textContent = `没有找到关于「${q}」的内容`;
					results.innerHTML = '';
					return;
				}
				hint.textContent = `找到 ${items.length} 条结果`;
				results.innerHTML = items
					.map(
						(it) => `
					<a class="result" href="${it.url}">
						<h3>${it.meta.title || it.url}</h3>
						<p class="excerpt">${it.excerpt}</p>
					</a>
				`,
					)
					.join('');
			}

			input.addEventListener('input', () => {
				clearTimeout(timer);
				timer = setTimeout(() => doSearch(input.value), 200);
			});
			button.addEventListener('click', () => doSearch(input.value));
			input.addEventListener('keydown', (e) => {
				if (e.key === 'Enter') doSearch(input.value);
			});

			document.addEventListener('keydown', (e) => {
				const tag = e.target.tagName;
				if (e.key === '/' && tag !== 'INPUT' && tag !== 'TEXTAREA') {
					e.preventDefault();
					input.focus();
				}
				if (e.key === 'Escape' && document.activeElement === input) {
					input.value = '';
					doSearch('');
				}
			});
		</script>

		<style>
			main {
				min-height: 50vh;
			}
			.search-bar {
				display: flex;
				gap: 0.5em;
				margin-bottom: 0.6em;
				align-items: center;
			}
			.search-input {
				flex: 1;
				padding: 0.65em 1em;
				font-family: inherit;
				font-size: 0.95em;
				background: rgba(255, 255, 255, 0.7);
				border: 1px solid rgba(255, 255, 255, 0.6);
				border-radius: 999px;
				color: rgb(var(--gray-dark));
				outline: none;
				transition: border-color 0.15s ease, background 0.15s ease;
			}
			.search-input::placeholder {
				color: rgba(96, 115, 159, 0.7);
			}
			.search-input:focus {
				background: rgba(255, 255, 255, 0.9);
				border-color: #ff90c0;
				box-shadow: 0 0 0 3px rgba(255, 144, 192, 0.15);
			}
			.search-btn {
				padding: 0.65em 1.6em;
				font-family: inherit;
				font-size: 0.95em;
				font-weight: 600;
				color: white;
				background: linear-gradient(135deg, #ff90c0, #ff70a8);
				border: none;
				border-radius: 999px;
				cursor: pointer;
				transition: transform 0.15s ease, box-shadow 0.15s ease;
				white-space: nowrap;
			}
			.search-btn:hover {
				transform: translateY(-1px);
				box-shadow: 0 6px 16px rgba(255, 112, 168, 0.3);
			}
			.search-btn:active {
				transform: translateY(0);
			}
			.hint {
				color: rgb(var(--gray));
				font-size: 0.88em;
				margin: 0 0 1.5em;
			}
			kbd {
				padding: 0.1em 0.4em;
				font-family: monospace;
				background: rgba(0, 0, 0, 0.06);
				border: 1px solid rgba(0, 0, 0, 0.1);
				border-radius: 4px;
				font-size: 0.9em;
			}
			.results {
				display: flex;
				flex-direction: column;
				gap: 0.8em;
			}
			:global(.result) {
				display: block;
				padding: 1em 1.2em;
				background: rgba(255, 255, 255, 0.5);
				border: 1px solid rgba(255, 255, 255, 0.45);
				border-radius: 12px;
				color: rgb(var(--gray-dark));
				text-decoration: none;
				transition: background 0.15s ease, transform 0.15s ease;
			}
			:global(.result:hover) {
				background: rgba(255, 255, 255, 0.8);
				transform: translateX(4px);
			}
			:global(.result h3) {
				margin: 0 0 0.3em;
				font-size: 1.05em;
				color: var(--accent);
			}
			:global(.result .excerpt) {
				margin: 0;
				font-size: 0.88em;
				color: rgb(var(--gray-dark));
				line-height: 1.5;
				opacity: 0.85;
			}
			:global(.result mark) {
				background: rgba(255, 200, 100, 0.4);
				color: inherit;
				padding: 0 0.15em;
				border-radius: 2px;
			}
		</style>
	</body>
</html>
