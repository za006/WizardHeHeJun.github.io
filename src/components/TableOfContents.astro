---
// 文章目录（TOC）
// - 桌面 ≥1280: 左侧 fixed 栏（不影响文章宽度，玻璃风）
// - 窄屏: 在 .prose 顶部显示一个胶囊触发器，点击展开下拉
// - 客户端从 .prose 的 h2/h3 标题构建；用 IntersectionObserver 做 scroll-spy
// 文章无 h2/h3 时整个组件不显示。
---

<aside class="toc-desktop" id="toc-desktop" aria-label="文章目录" hidden>
	<button class="toc-head-pill" type="button" aria-label="文章目录">
		<svg viewBox="0 0 24 24" width="13" height="13" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"
			><line x1="8" y1="6" x2="21" y2="6"></line><line x1="8" y1="12" x2="21" y2="12"></line><line x1="8" y1="18" x2="21" y2="18"></line><line x1="3" y1="6" x2="3.01" y2="6"></line><line x1="3" y1="12" x2="3.01" y2="12"></line><line x1="3" y1="18" x2="3.01" y2="18"></line></svg
		>
		<span>文章目录</span>
	</button>
	<nav class="toc-list-wrap"><ul class="toc-list" id="toc-list-desktop"></ul></nav>
	<div class="toc-footer">
		<button class="toc-action" type="button" data-scroll-top aria-label="返回顶部">
			<svg viewBox="0 0 24 24" width="14" height="14" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"
				><polyline points="18 15 12 9 6 15"></polyline></svg
			>
			<span>回到顶部</span>
		</button>
		<button class="toc-action" type="button" data-scroll-bottom aria-label="滚到底部">
			<svg viewBox="0 0 24 24" width="14" height="14" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"
				><polyline points="6 9 12 15 18 9"></polyline></svg
			>
			<span>滚到底部</span>
		</button>
	</div>
</aside>

<!-- 右下角浮动按钮组：回到顶部 / 滚到底部 / 折叠切换。窄屏可见（桌面已在 TOC 侧栏内部有相同按钮） -->
<div class="toc-fab" id="toc-fab" hidden>
	<button class="toc-fab-btn toc-fab-scroll" type="button" data-fab-scroll-top aria-label="回到顶部">
		<svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"
			><polyline points="18 15 12 9 6 15"></polyline></svg
		>
	</button>
	<button class="toc-fab-btn toc-fab-scroll" type="button" data-fab-scroll-bottom aria-label="滚到底部">
		<svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"
			><polyline points="6 9 12 15 18 9"></polyline></svg
		>
	</button>
	<button class="toc-fab-btn toc-fab-toggle" type="button" data-fab-toggle aria-label="折叠 / 展开" aria-expanded="true">
		<svg class="toc-fab-icon-close" viewBox="0 0 24 24" width="20" height="20" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"
			><line x1="6" y1="6" x2="18" y2="18"></line><line x1="6" y1="18" x2="18" y2="6"></line></svg
		>
		<svg class="toc-fab-icon-open" viewBox="0 0 24 24" width="20" height="20" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"
			><line x1="8" y1="6" x2="21" y2="6"></line><line x1="8" y1="12" x2="21" y2="12"></line><line x1="8" y1="18" x2="21" y2="18"></line><line x1="3" y1="6" x2="3.01" y2="6"></line><line x1="3" y1="12" x2="3.01" y2="12"></line><line x1="3" y1="18" x2="3.01" y2="18"></line></svg
		>
	</button>
</div>

<div class="toc-mobile" id="toc-mobile" hidden>
	<button class="toc-mobile-trigger" id="toc-mobile-trigger" aria-expanded="false" aria-controls="toc-mobile-panel">
		<!-- 书签/章节图标 — 和 header 的 hamburger 区分开，避免两个 ☰ 视觉冲突 -->
		<svg viewBox="0 0 24 24" width="15" height="15" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
			><path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"></path></svg
		>
		<span class="toc-mobile-current" id="toc-mobile-current">目录</span>
		<svg class="toc-chevron" viewBox="0 0 24 24" width="14" height="14" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"
			><polyline points="6 9 12 15 18 9"></polyline></svg
		>
	</button>
	<div class="toc-mobile-panel" id="toc-mobile-panel"><ul class="toc-list" id="toc-list-mobile"></ul></div>
</div>

<script is:inline>
	const initTOC = () => {
		const prose = document.querySelector('.prose');
		if (!prose) return;
		const headings = Array.from(prose.querySelectorAll('h2, h3'));
		if (headings.length === 0) return;

		const slugify = (text) =>
			text
				.trim()
				.toLowerCase()
				.replace(/[^\w一-龥\s-]/g, '')
				.replace(/\s+/g, '-')
				.replace(/-+/g, '-')
				.replace(/^-|-$/g, '');

		// 给所有标题加 ID + 收集编号
		const used = new Set();
		const items = [];
		let n2 = 0, n3 = 0;
		headings.forEach((h) => {
			const level = parseInt(h.tagName.slice(1));
			if (level === 2) { n2++; n3 = 0; }
			else { n3++; }
			if (!h.id) {
				let base = slugify(h.textContent || '') || 'section';
				let id = base, i = 1;
				while (used.has(id) || document.getElementById(id)) {
					id = `${base}-${i++}`;
				}
				h.id = id;
			}
			used.add(h.id);
			const num = level === 2 ? `${n2}.` : `${n2}.${n3}`;
			items.push({ id: h.id, text: h.textContent || '', level, num, el: h });
		});

		// 渲染列表 HTML
		const renderList = () =>
			items
				.map(
					(it) => `
				<li class="toc-item toc-l${it.level}" data-id="${it.id}">
					<a href="#${it.id}">
						<span class="toc-num">${it.num}</span>
						<span class="toc-text">${it.text.replace(/</g, '&lt;')}</span>
					</a>
				</li>`,
				)
				.join('');

		const html = renderList();
		const desktopList = document.getElementById('toc-list-desktop');
		const mobileList = document.getElementById('toc-list-mobile');
		const desktop = document.getElementById('toc-desktop');
		const mobile = document.getElementById('toc-mobile');
		const trigger = document.getElementById('toc-mobile-trigger');
		const panel = document.getElementById('toc-mobile-panel');
		const currentLabel = document.getElementById('toc-mobile-current');
		if (desktopList) desktopList.innerHTML = html;
		if (mobileList) mobileList.innerHTML = html;
		desktop.hidden = false;
		mobile.hidden = false;

		// 平滑滚动 + 关闭移动端面板
		const closeMobile = () => {
			mobile.classList.remove('is-open');
			trigger.setAttribute('aria-expanded', 'false');
		};
		document.querySelectorAll('.toc-list a').forEach((a) => {
			a.addEventListener('click', (e) => {
				const id = a.getAttribute('href')?.slice(1);
				if (!id) return;
				const target = document.getElementById(id);
				if (!target) return;
				e.preventDefault();
				const top = target.getBoundingClientRect().top + window.scrollY - 72;
				window.scrollTo({ top, behavior: 'smooth' });
				history.replaceState(null, '', `#${id}`);
				closeMobile();
			});
		});

		// 移动端触发器
		trigger.addEventListener('click', () => {
			const open = mobile.classList.toggle('is-open');
			trigger.setAttribute('aria-expanded', open ? 'true' : 'false');
		});
		document.addEventListener('click', (e) => {
			if (!mobile.classList.contains('is-open')) return;
			if (!mobile.contains(e.target)) closeMobile();
		});
		document.addEventListener('keydown', (e) => {
			if (e.key === 'Escape' && mobile.classList.contains('is-open')) closeMobile();
		});

		// Scroll-spy：哪一节标题离视口顶部最近就高亮
		const idToItems = new Map();
		document.querySelectorAll('.toc-item').forEach((li) => {
			const id = li.getAttribute('data-id');
			if (!id) return;
			if (!idToItems.has(id)) idToItems.set(id, []);
			idToItems.get(id).push(li);
		});

		const setActive = (id) => {
			document.querySelectorAll('.toc-item.is-active').forEach((li) => li.classList.remove('is-active'));
			const lis = idToItems.get(id) || [];
			lis.forEach((li) => li.classList.add('is-active'));
			// 更新移动端胶囊上的当前标题
			const item = items.find((it) => it.id === id);
			if (item && currentLabel) currentLabel.textContent = `${item.num} ${item.text}`;
			// 让桌面端的高亮项滚入视野
			const desktopLi = lis.find((li) => li.closest('#toc-desktop'));
			if (desktopLi) desktopLi.scrollIntoView({ block: 'nearest' });
		};

		// 找当前最贴近顶部（但已进入视口）的 heading
		let raf = 0;
		const recompute = () => {
			raf = 0;
			let activeId = items[0].id;
			const offset = 96; // header 高度 + 缓冲
			for (const it of items) {
				const rect = it.el.getBoundingClientRect();
				if (rect.top - offset <= 0) activeId = it.id;
				else break;
			}
			setActive(activeId);
		};
		window.addEventListener(
			'scroll',
			() => {
				if (!raf) raf = requestAnimationFrame(recompute);
			},
			{ passive: true },
		);
		recompute();

		/* —— TOC 位置：未滚出 hero 时贴在 hero 下方，滚出后吸顶
		   用 transform: translateY 走 GPU 合成层，避免每帧 layout 重排 —— */
		const hero = document.querySelector('.hero-image');
		let curTop = -1;
		const updateTocTop = () => {
			if (!hero || !desktop) return;
			const stickyTop = document.body.classList.contains('header-hidden') ? 20 : 80;
			const heroRect = hero.getBoundingClientRect();
			const top = Math.max(stickyTop, Math.round(heroRect.bottom + 20));
			if (top === curTop) return; // 避免无意义重绘
			curTop = top;
			desktop.style.transform = `translateY(${top}px)`;
		};
		let rafTop = 0;
		const onScrollTop = () => {
			if (!rafTop) rafTop = requestAnimationFrame(() => { updateTocTop(); rafTop = 0; });
		};
		window.addEventListener('scroll', onScrollTop, { passive: true });
		window.addEventListener('resize', onScrollTop, { passive: true });
		updateTocTop();

		/* —— 跳转按钮：桌面 sidebar 内 + 移动 FAB 浮动 —— */
		const scrollTop = () => window.scrollTo({ top: 0, behavior: 'smooth' });
		const scrollBottom = () => window.scrollTo({ top: document.documentElement.scrollHeight, behavior: 'smooth' });
		document.querySelectorAll('[data-scroll-top], [data-fab-scroll-top]').forEach((b) =>
			b.addEventListener('click', scrollTop),
		);
		document.querySelectorAll('[data-scroll-bottom], [data-fab-scroll-bottom]').forEach((b) =>
			b.addEventListener('click', scrollBottom),
		);
		const fab = document.getElementById('toc-fab');
		if (fab) fab.hidden = false;
		const fabToggle = document.querySelector('[data-fab-toggle]');
		fabToggle?.addEventListener('click', () => {
			const collapsed = fab?.classList.toggle('is-collapsed');
			fabToggle.setAttribute('aria-expanded', collapsed ? 'false' : 'true');
		});

		/* —— 标记 body：在 ≤640 视口下，CSS 会把 TOC bar 浮到 header 替代 ticker —— */
		document.body.classList.add('has-toc');
	};

	if (document.readyState === 'loading') {
		document.addEventListener('DOMContentLoaded', initTOC);
	} else {
		initTOC();
	}
</script>

<style is:global>
	/* ━━━━━━━━━━ 桌面端：左侧贴边固定栏（≥1280） ━━━━━━━━━━ */
	.toc-desktop {
		position: fixed;
		top: 0;
		left: 16px;
		width: 240px;
		max-height: calc(100vh - 100px);
		display: none;
		padding: 0.4em 0.6em 0.6em;
		background: transparent;
		z-index: 5;
		flex-direction: column;
		overflow: hidden;
		/* 位置走 transform（GPU 合成），不走 top（layout 重排）—— scroll 时丝滑 */
		transform: translateY(80px);
		will-change: transform;
	}
	@media (min-width: 1280px) {
		.toc-desktop:not([hidden]) {
			display: flex;
		}
	}
	@media (min-width: 1400px) {
		.toc-desktop {
			left: 24px;
			width: 260px;
		}
	}
	@media (min-width: 1600px) {
		.toc-desktop {
			left: 32px;
			width: 280px;
		}
	}
	/* 顶部胶囊：文章目录 */
	.toc-head-pill {
		display: inline-flex;
		align-items: center;
		gap: 0.4em;
		margin: 0 auto 0.9em;
		padding: 0.4em 0.95em;
		font-family: inherit;
		font-size: 0.85em;
		font-weight: 600;
		color: #c2185b;
		background: linear-gradient(135deg, rgba(255, 209, 228, 0.95), rgba(255, 183, 197, 0.95));
		border: none;
		border-radius: 999px;
		box-shadow: 0 2px 8px rgba(255, 144, 192, 0.25);
		cursor: default;
		letter-spacing: 0.04em;
	}
	.toc-desktop .toc-list-wrap {
		flex: 1;
		min-height: 0;
		overflow-y: auto;
		margin-right: -0.4em;
		padding-right: 0.4em;
		/* 底部柔和淡出遮罩，避免硬切 */
		-webkit-mask-image: linear-gradient(180deg, black 0%, black calc(100% - 28px), transparent 100%);
		mask-image: linear-gradient(180deg, black 0%, black calc(100% - 28px), transparent 100%);
	}
	.toc-desktop .toc-list-wrap::-webkit-scrollbar {
		width: 4px;
	}
	.toc-desktop .toc-list-wrap::-webkit-scrollbar-thumb {
		background: rgba(0, 0, 0, 0.12);
		border-radius: 2px;
	}

	/* —— 底部跳转按钮组 —— */
	.toc-footer {
		display: flex;
		gap: 0.45em;
		margin-top: 0.6em;
		padding-top: 0.5em;
		flex-shrink: 0;
	}
	.toc-action {
		flex: 1;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 0.35em;
		padding: 0.5em 0.4em;
		font-family: inherit;
		font-size: 0.78em;
		font-weight: 500;
		color: #c2185b;
		background: rgba(255, 209, 228, 0.5);
		border: 1px solid rgba(255, 144, 192, 0.35);
		border-radius: 10px;
		cursor: pointer;
		transition: background 0.15s ease, transform 0.15s ease, box-shadow 0.15s ease;
	}
	.toc-action:hover {
		background: rgba(255, 183, 197, 0.85);
		transform: translateY(-1px);
		box-shadow: 0 4px 12px rgba(255, 144, 192, 0.25);
	}
	.toc-action svg {
		flex-shrink: 0;
	}

	/* ━━━━━━━━━━ 列表项通用样式 ━━━━━━━━━━ */
	.toc-list {
		list-style: none;
		margin: 0;
		padding: 0;
	}
	.toc-item {
		margin: 0;
		position: relative;
	}
	.toc-item a {
		display: flex;
		gap: 0.45em;
		align-items: baseline;
		padding: 0.5em 0.85em;
		border-radius: 10px;
		color: rgb(var(--gray-dark));
		text-decoration: none;
		font-size: 0.92em;
		line-height: 1.45;
		transition: background 0.18s ease, color 0.18s ease;
	}
	.toc-item a:hover {
		background: rgba(255, 144, 192, 0.08);
		color: #c2185b;
	}
	.toc-num {
		flex-shrink: 0;
		min-width: 1.6em;
		color: rgb(var(--gray));
		font-variant-numeric: tabular-nums;
		font-weight: 500;
	}
	.toc-text {
		flex: 1;
		min-width: 0;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}
	/* h3：缩进 + 稍小 + 灰一点 */
	.toc-l3 a {
		padding-left: 1.9em;
		font-size: 0.84em;
		color: rgb(var(--gray));
	}
	.toc-l3 .toc-num {
		min-width: 2.4em;
		font-size: 0.92em;
	}
	/* 主动态：粉色胶囊 + 右侧小圆点 */
	.toc-item.is-active a {
		background: linear-gradient(135deg, rgba(255, 209, 228, 0.95), rgba(255, 183, 197, 0.85));
		color: #c2185b !important;
		font-weight: 600;
	}
	.toc-item.is-active .toc-num {
		color: #c2185b;
		font-weight: 600;
	}
	.toc-item.is-active a::after {
		content: '';
		flex-shrink: 0;
		width: 5px;
		height: 5px;
		border-radius: 50%;
		background: #c2185b;
		margin-left: 0.3em;
		align-self: center;
	}

	/* ━━━━━━━━━━ 移动端：顶部胶囊触发器 + 下拉面板（<1280） ━━━━━━━━━━ */
	.toc-mobile {
		display: none;
		position: sticky;
		top: 64px;
		z-index: 9;
		width: min(840px, 100% - 2em);
		margin: 0 auto 0.8em;
	}
	@media (max-width: 1279px) {
		.toc-mobile:not([hidden]) {
			display: block;
		}
	}
	@media (min-width: 1400px) {
		.toc-mobile {
			width: min(960px, 100% - 4em);
		}
	}
	.toc-mobile-trigger {
		display: flex;
		align-items: center;
		gap: 0.6em;
		width: 100%;
		padding: 0.5em 0.9em;
		font-family: inherit;
		font-size: 0.9em;
		color: rgb(var(--gray-dark));
		background: rgba(255, 255, 255, 0.82);
		backdrop-filter: blur(12px) saturate(170%);
		-webkit-backdrop-filter: blur(12px) saturate(170%);
		border: 1px solid rgba(255, 255, 255, 0.7);
		border-radius: 999px;
		box-shadow: 0 2px 8px rgba(31, 38, 135, 0.08);
		cursor: pointer;
		text-align: left;
		transition: background 0.15s ease, box-shadow 0.15s ease;
	}
	.toc-mobile-trigger:hover {
		background: rgba(255, 255, 255, 0.95);
	}
	.toc-mobile-current {
		flex: 1;
		min-width: 0;
		white-space: nowrap;
		overflow: hidden;
		text-overflow: ellipsis;
	}
	.toc-chevron {
		flex-shrink: 0;
		color: rgb(var(--gray));
		transition: transform 0.2s ease;
	}
	.toc-mobile.is-open .toc-chevron {
		transform: rotate(180deg);
	}
	.toc-mobile-panel {
		position: absolute;
		top: calc(100% + 6px);
		left: 0;
		right: 0;
		max-height: 60vh;
		overflow-y: auto;
		padding: 0.5em;
		background: rgba(255, 255, 255, 0.96);
		backdrop-filter: blur(16px) saturate(180%);
		-webkit-backdrop-filter: blur(16px) saturate(180%);
		border: 1px solid rgba(255, 255, 255, 0.7);
		border-radius: 14px;
		box-shadow: 0 12px 36px rgba(31, 38, 135, 0.2);
		opacity: 0;
		transform: translateY(-6px);
		pointer-events: none;
		transition: opacity 0.18s ease, transform 0.18s ease;
	}
	.toc-mobile.is-open .toc-mobile-panel {
		opacity: 1;
		transform: translateY(0);
		pointer-events: auto;
	}
	@media (prefers-reduced-motion: reduce) {
		.toc-chevron,
		.toc-mobile-panel {
			transition: none;
		}
	}

	/* ━━━ ≤640 视口：TOC bar 通过 fixed 浮到 header 位置占替代 ticker ━━━ */
	@media (max-width: 640px) {
		/* 隐藏原 ticker（最近文章），让 TOC bar 占位 */
		body.has-toc header .ticker {
			display: none !important;
		}
		body.has-toc .toc-mobile {
			position: fixed !important;
			top: 7px;
			/* 横向间距回到一开始那样 */
			left: 50px;
			right: 48px;
			width: auto !important;
			max-width: none;
			margin: 0 !important;
			z-index: 11;
			transition: transform 0.28s cubic-bezier(0.4, 0, 0.2, 1);
		}
		/* 跟着 header 一起隐藏（header.is-hidden → body.header-hidden） */
		body.has-toc.header-hidden .toc-mobile {
			transform: translateY(-160%);
		}
		/* trigger 改成 ticker 同款玻璃胶囊，加高让胶囊更厚实 */
		body.has-toc .toc-mobile-trigger {
			height: 3em;
			padding: 0 0.85em 0 0.7em;
			font-size: 0.9em;
