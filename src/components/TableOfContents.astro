---
// 文章目录（TOC）
// - 桌面 ≥1280: 左侧 fixed 栏（不影响文章宽度，玻璃风）
// - 窄屏: 在 .prose 顶部显示一个胶囊触发器，点击展开下拉
// - 客户端从 .prose 的 h2/h3 标题构建；用 IntersectionObserver 做 scroll-spy
// 文章无 h2/h3 时整个组件不显示。
---

<aside class="toc-desktop" id="toc-desktop" aria-label="文章目录" hidden>
	<div class="toc-head">
		<svg viewBox="0 0 24 24" width="14" height="14" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
			><line x1="8" y1="6" x2="21" y2="6"></line><line x1="8" y1="12" x2="21" y2="12"></line><line x1="8" y1="18" x2="21" y2="18"></line><line x1="3" y1="6" x2="3.01" y2="6"></line><line x1="3" y1="12" x2="3.01" y2="12"></line><line x1="3" y1="18" x2="3.01" y2="18"></line></svg
		>
		<span>目录</span>
	</div>
	<nav class="toc-list-wrap"><ul class="toc-list" id="toc-list-desktop"></ul></nav>
</aside>

<div class="toc-mobile" id="toc-mobile" hidden>
	<button class="toc-mobile-trigger" id="toc-mobile-trigger" aria-expanded="false" aria-controls="toc-mobile-panel">
		<svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
			><line x1="8" y1="6" x2="21" y2="6"></line><line x1="8" y1="12" x2="21" y2="12"></line><line x1="8" y1="18" x2="21" y2="18"></line><line x1="3" y1="6" x2="3.01" y2="6"></line><line x1="3" y1="12" x2="3.01" y2="12"></line><line x1="3" y1="18" x2="3.01" y2="18"></line></svg
		>
		<span class="toc-mobile-current" id="toc-mobile-current">目录</span>
		<svg class="toc-chevron" viewBox="0 0 24 24" width="14" height="14" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"
			><polyline points="6 9 12 15 18 9"></polyline></svg
		>
	</button>
	<div class="toc-mobile-panel" id="toc-mobile-panel"><ul class="toc-list" id="toc-list-mobile"></ul></div>
</div>

<script is:inline>
	(() => {
		const prose = document.querySelector('.prose');
		if (!prose) return;
		const headings = Array.from(prose.querySelectorAll('h2, h3'));
		if (headings.length === 0) return;

		const slugify = (text) =>
			text
				.trim()
				.toLowerCase()
				.replace(/[^\w一-龥\s-]/g, '')
				.replace(/\s+/g, '-')
				.replace(/-+/g, '-')
				.replace(/^-|-$/g, '');

		// 给所有标题加 ID + 收集编号
		const used = new Set();
		const items = [];
		let n2 = 0, n3 = 0;
		headings.forEach((h) => {
			const level = parseInt(h.tagName.slice(1));
			if (level === 2) { n2++; n3 = 0; }
			else { n3++; }
			if (!h.id) {
				let base = slugify(h.textContent || '') || 'section';
				let id = base, i = 1;
				while (used.has(id) || document.getElementById(id)) {
					id = `${base}-${i++}`;
				}
				h.id = id;
			}
			used.add(h.id);
			const num = level === 2 ? `${n2}.` : `${n2}.${n3}`;
			items.push({ id: h.id, text: h.textContent || '', level, num, el: h });
		});

		// 渲染列表 HTML
		const renderList = () =>
			items
				.map(
					(it) => `
				<li class="toc-item toc-l${it.level}" data-id="${it.id}">
					<a href="#${it.id}">
						<span class="toc-num">${it.num}</span>
						<span class="toc-text">${it.text.replace(/</g, '&lt;')}</span>
					</a>
				</li>`,
				)
				.join('');

		const html = renderList();
		const desktopList = document.getElementById('toc-list-desktop');
		const mobileList = document.getElementById('toc-list-mobile');
		const desktop = document.getElementById('toc-desktop');
		const mobile = document.getElementById('toc-mobile');
		const trigger = document.getElementById('toc-mobile-trigger');
		const panel = document.getElementById('toc-mobile-panel');
		const currentLabel = document.getElementById('toc-mobile-current');
		if (desktopList) desktopList.innerHTML = html;
		if (mobileList) mobileList.innerHTML = html;
		desktop.hidden = false;
		mobile.hidden = false;

		// 平滑滚动 + 关闭移动端面板
		const closeMobile = () => {
			mobile.classList.remove('is-open');
			trigger.setAttribute('aria-expanded', 'false');
		};
		document.querySelectorAll('.toc-list a').forEach((a) => {
			a.addEventListener('click', (e) => {
				const id = a.getAttribute('href')?.slice(1);
				if (!id) return;
				const target = document.getElementById(id);
				if (!target) return;
				e.preventDefault();
				const top = target.getBoundingClientRect().top + window.scrollY - 72;
				window.scrollTo({ top, behavior: 'smooth' });
				history.replaceState(null, '', `#${id}`);
				closeMobile();
			});
		});

		// 移动端触发器
		trigger.addEventListener('click', () => {
			const open = mobile.classList.toggle('is-open');
			trigger.setAttribute('aria-expanded', open ? 'true' : 'false');
		});
		document.addEventListener('click', (e) => {
			if (!mobile.classList.contains('is-open')) return;
			if (!mobile.contains(e.target)) closeMobile();
		});
		document.addEventListener('keydown', (e) => {
			if (e.key === 'Escape' && mobile.classList.contains('is-open')) closeMobile();
		});

		// Scroll-spy：哪一节标题离视口顶部最近就高亮
		const idToItems = new Map();
		document.querySelectorAll('.toc-item').forEach((li) => {
			const id = li.getAttribute('data-id');
			if (!id) return;
			if (!idToItems.has(id)) idToItems.set(id, []);
			idToItems.get(id).push(li);
		});

		const setActive = (id) => {
			document.querySelectorAll('.toc-item.is-active').forEach((li) => li.classList.remove('is-active'));
			const lis = idToItems.get(id) || [];
			lis.forEach((li) => li.classList.add('is-active'));
			// 更新移动端胶囊上的当前标题
			const item = items.find((it) => it.id === id);
			if (item && currentLabel) currentLabel.textContent = `${item.num} ${item.text}`;
			// 让桌面端的高亮项滚入视野
			const desktopLi = lis.find((li) => li.closest('#toc-desktop'));
			if (desktopLi) desktopLi.scrollIntoView({ block: 'nearest' });
		};

		// 找当前最贴近顶部（但已进入视口）的 heading
		let raf = 0;
		const recompute = () => {
			raf = 0;
			let activeId = items[0].id;
			const offset = 96; // header 高度 + 缓冲
			for (const it of items) {
				const rect = it.el.getBoundingClientRect();
				if (rect.top - offset <= 0) activeId = it.id;
				else break;
			}
			setActive(activeId);
		};
		window.addEventListener(
			'scroll',
			() => {
				if (!raf) raf = requestAnimationFrame(recompute);
			},
			{ passive: true },
		);
		recompute();
	})();
</script>

<style is:global>
	/* ━━━━━━━━━━ 桌面端：左侧固定栏（≥1280） ━━━━━━━━━━ */
	.toc-desktop {
		position: fixed;
		top: 96px;
		left: max(20px, calc(50vw - 420px - 220px - 24px));
		width: 220px;
		max-height: calc(100vh - 120px);
		display: none;
		padding: 0.9em 0.6em 0.9em 1em;
		background: rgba(255, 255, 255, 0.55);
		backdrop-filter: blur(14px) saturate(170%);
		-webkit-backdrop-filter: blur(14px) saturate(170%);
		border: 1px solid rgba(255, 255, 255, 0.5);
		border-radius: 14px;
		box-shadow: 0 4px 16px rgba(31, 38, 135, 0.1);
		z-index: 5;
		flex-direction: column;
		overflow: hidden;
	}
	@media (min-width: 1280px) {
		.toc-desktop:not([hidden]) {
			display: flex;
		}
	}
	@media (min-width: 1400px) {
		.toc-desktop {
			left: max(24px, calc(50vw - 480px - 240px - 28px));
			width: 240px;
		}
	}
	.toc-head {
		display: flex;
		align-items: center;
		gap: 0.45em;
		font-size: 0.82em;
		font-weight: 700;
		color: rgb(var(--gray));
		padding-bottom: 0.55em;
		margin-bottom: 0.35em;
		border-bottom: 1px dashed rgba(0, 0, 0, 0.08);
		letter-spacing: 0.04em;
	}
	.toc-desktop .toc-list-wrap {
		overflow-y: auto;
		max-height: calc(100vh - 180px);
		margin-right: -0.4em;
		padding-right: 0.4em;
	}
	.toc-desktop .toc-list-wrap::-webkit-scrollbar {
		width: 4px;
	}
	.toc-desktop .toc-list-wrap::-webkit-scrollbar-thumb {
		background: rgba(0, 0, 0, 0.12);
		border-radius: 2px;
	}

	/* ━━━━━━━━━━ 列表项通用样式 ━━━━━━━━━━ */
	.toc-list {
		list-style: none;
		margin: 0;
		padding: 0;
	}
	.toc-item {
		margin: 0;
	}
	.toc-item a {
		display: flex;
		gap: 0.4em;
		align-items: flex-start;
		padding: 0.35em 0.5em;
		border-radius: 6px;
		color: rgb(var(--gray-dark));
		text-decoration: none;
		font-size: 0.85em;
		line-height: 1.4;
		transition: background 0.15s ease, color 0.15s ease;
	}
	.toc-item a:hover {
		background: rgba(35, 55, 255, 0.06);
		color: var(--accent);
	}
	.toc-num {
		flex-shrink: 0;
		min-width: 1.8em;
		color: rgb(var(--gray));
		font-variant-numeric: tabular-nums;
		font-size: 0.95em;
	}
	.toc-text {
		flex: 1;
		min-width: 0;
	}
	.toc-l3 a {
		padding-left: 1.6em;
		font-size: 0.8em;
	}
	.toc-l3 .toc-num {
		min-width: 2.4em;
	}
	.toc-item.is-active a {
		background: rgba(255, 144, 192, 0.18);
		color: #b8541e;
		font-weight: 600;
	}
	.toc-item.is-active .toc-num {
		color: #b8541e;
	}

	/* ━━━━━━━━━━ 移动端：顶部胶囊触发器 + 下拉面板（<1280） ━━━━━━━━━━ */
	.toc-mobile {
		display: none;
		position: sticky;
		top: 64px;
		z-index: 9;
		width: min(840px, 100% - 2em);
		margin: 0 auto 0.8em;
	}
	@media (max-width: 1279px) {
		.toc-mobile:not([hidden]) {
			display: block;
		}
	}
	@media (min-width: 1400px) {
		.toc-mobile {
			width: min(960px, 100% - 4em);
		}
	}
	.toc-mobile-trigger {
		display: flex;
		align-items: center;
		gap: 0.6em;
		width: 100%;
		padding: 0.5em 0.9em;
		font-family: inherit;
		font-size: 0.9em;
		color: rgb(var(--gray-dark));
		background: rgba(255, 255, 255, 0.82);
		backdrop-filter: blur(12px) saturate(170%);
		-webkit-backdrop-filter: blur(12px) saturate(170%);
		border: 1px solid rgba(255, 255, 255, 0.7);
		border-radius: 999px;
		box-shadow: 0 2px 8px rgba(31, 38, 135, 0.08);
		cursor: pointer;
		text-align: left;
		transition: background 0.15s ease, box-shadow 0.15s ease;
	}
	.toc-mobile-trigger:hover {
		background: rgba(255, 255, 255, 0.95);
	}
	.toc-mobile-current {
		flex: 1;
		min-width: 0;
		white-space: nowrap;
		overflow: hidden;
		text-overflow: ellipsis;
	}
	.toc-chevron {
		flex-shrink: 0;
		color: rgb(var(--gray));
		transition: transform 0.2s ease;
	}
	.toc-mobile.is-open .toc-chevron {
		transform: rotate(180deg);
	}
	.toc-mobile-panel {
		position: absolute;
		top: calc(100% + 6px);
		left: 0;
		right: 0;
		max-height: 60vh;
		overflow-y: auto;
		padding: 0.5em;
		background: rgba(255, 255, 255, 0.96);
		backdrop-filter: blur(16px) saturate(180%);
		-webkit-backdrop-filter: blur(16px) saturate(180%);
		border: 1px solid rgba(255, 255, 255, 0.7);
		border-radius: 14px;
		box-shadow: 0 12px 36px rgba(31, 38, 135, 0.2);
		opacity: 0;
		transform: translateY(-6px);
		pointer-events: none;
		transition: opacity 0.18s ease, transform 0.18s ease;
	}
	.toc-mobile.is-open .toc-mobile-panel {
		opacity: 1;
		transform: translateY(0);
		pointer-events: auto;
	}
	@media (prefers-reduced-motion: reduce) {
		.toc-chevron,
		.toc-mobile-panel {
			transition: none;
		}
	}

	/* 锚点滚动时给标题留出一点 padding（不被 header 盖住） */
	.prose h2,
	.prose h3 {
		scroll-margin-top: 80px;
	}
</style>
