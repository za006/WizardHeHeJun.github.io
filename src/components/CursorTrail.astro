---
// 鼠标轨迹：节流的 mousemove → 空心几何菱形 + 弹出 / 旋转 / 发光 / 缩放淡出
// 触屏设备自动跳过；prefers-reduced-motion 时也不创建
---

<script is:inline>
	(function () {
		// 跳过触屏设备 + 减少动画偏好
		if (
			window.matchMedia('(hover: none), (pointer: coarse)').matches ||
			window.matchMedia('(prefers-reduced-motion: reduce)').matches
		) {
			return;
		}

		const colors = ['#ff90c0', '#7ab5ff', '#c280ff'];
		let lastT = 0;
		let colorIdx = 0;
		let toggle = 0;
		const MAX = 28; // 最大同时存在数量
		const LIFE = 1100; // 单点生命周期（ms）
		const queue = [];

		document.addEventListener(
			'mousemove',
			(e) => {
				const now = performance.now();
				if (now - lastT < 25) return; // 节流 ~40fps
				lastT = now;

				const dot = document.createElement('span');
				// 大小交替：大菱形 + 小圆点交错，更有节奏感
				dot.className = toggle % 2 === 0 ? 'cursor-trail-dot' : 'cursor-trail-dot small';
				dot.style.left = e.clientX + 'px';
				dot.style.top = e.clientY + 'px';
				dot.style.color = colors[colorIdx];
				colorIdx = (colorIdx + 1) % colors.length;
				toggle++;

				document.body.appendChild(dot);
				queue.push(dot);
				if (queue.length > MAX) {
					const old = queue.shift();
					old?.remove();
				}
				setTimeout(() => {
					dot.remove();
					const i = queue.indexOf(dot);
					if (i >= 0) queue.splice(i, 1);
				}, LIFE);
			},
			{ passive: true },
		);
	})();
</script>

<style is:global>
	.cursor-trail-dot {
		position: fixed;
		pointer-events: none;
		width: 22px;
		height: 22px;
		border: 2.2px solid currentColor;
		background: transparent;
		transform: translate(-50%, -50%) rotate(45deg) scale(0.3);
		opacity: 0;
		z-index: 9999;
		box-shadow:
			0 0 8px currentColor,
			inset 0 0 4px currentColor;
		animation: cursor-trail-fade 1100ms cubic-bezier(0.34, 1.36, 0.64, 1) forwards;
	}
	/* 小圆点：交错出现，制造节奏 */
	.cursor-trail-dot.small {
		width: 10px;
		height: 10px;
		border-width: 1.8px;
		border-radius: 50%;
		animation-name: cursor-trail-fade-dot;
	}
	@keyframes cursor-trail-fade {
		0% {
			opacity: 0;
			transform: translate(-50%, -50%) rotate(0deg) scale(0.3);
		}
		15% {
			opacity: 1;
			transform: translate(-50%, -50%) rotate(60deg) scale(1.45);
		}
		35% {
			opacity: 0.95;
			transform: translate(-50%, -50%) rotate(160deg) scale(1.1);
		}
		100% {
			opacity: 0;
			transform: translate(-50%, -50%) rotate(540deg) scale(0.15);
		}
	}
	@keyframes cursor-trail-fade-dot {
		0% {
			opacity: 0;
			transform: translate(-50%, -50%) rotate(0deg) scale(0.2);
		}
		20% {
			opacity: 1;
			transform: translate(-50%, -50%) rotate(0deg) scale(1.6);
		}
		100% {
			opacity: 0;
			transform: translate(-50%, -50%) rotate(0deg) scale(0.1);
		}
	}
</style>
