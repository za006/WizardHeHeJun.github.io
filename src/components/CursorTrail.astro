---
// 鼠标轨迹：节流的 mousemove → 空心几何菱形 + 轻旋转 + 淡出
// 触屏设备自动跳过；prefers-reduced-motion 时也不创建
---

<script is:inline>
	(function () {
		// 跳过触屏设备 + 减少动画偏好
		if (
			window.matchMedia('(hover: none), (pointer: coarse)').matches ||
			window.matchMedia('(prefers-reduced-motion: reduce)').matches
		) {
			return;
		}

		const colors = ['#ff90c0', '#7ab5ff'];
		let lastT = 0;
		let colorIdx = 0;
		const MAX = 18;
		const LIFE = 850;
		const queue = [];

		document.addEventListener(
			'mousemove',
			(e) => {
				const now = performance.now();
				if (now - lastT < 30) return;
				lastT = now;

				const dot = document.createElement('span');
				dot.className = 'cursor-trail-dot';
				dot.style.left = e.clientX + 'px';
				dot.style.top = e.clientY + 'px';
				dot.style.color = colors[colorIdx];
				colorIdx = (colorIdx + 1) % colors.length;

				document.body.appendChild(dot);
				queue.push(dot);
				if (queue.length > MAX) {
					const old = queue.shift();
					old?.remove();
				}
				setTimeout(() => {
					dot.remove();
					const i = queue.indexOf(dot);
					if (i >= 0) queue.splice(i, 1);
				}, LIFE);
			},
			{ passive: true },
		);
	})();
</script>

<style is:global>
	.cursor-trail-dot {
		position: fixed;
		pointer-events: none;
		width: 18px;
		height: 18px;
		border: 1.8px solid currentColor;
		background: transparent;
		transform: translate(-50%, -50%) rotate(45deg);
		opacity: 0;
		z-index: 9999;
		box-shadow: 0 0 5px currentColor;
		animation: cursor-trail-fade 850ms cubic-bezier(0.4, 0, 0.6, 1) forwards;
	}
	@keyframes cursor-trail-fade {
		0% {
			opacity: 0;
			transform: translate(-50%, -50%) rotate(45deg) scale(0.5);
		}
		20% {
			opacity: 0.85;
			transform: translate(-50%, -50%) rotate(75deg) scale(1.05);
		}
		100% {
			opacity: 0;
			transform: translate(-50%, -50%) rotate(225deg) scale(0.2);
		}
	}
</style>
