<script is:inline>
	(() => {
		const drawer = document.querySelector('[data-drawer]');
		const backdrop = document.querySelector('[data-drawer-backdrop]');
		if (!drawer || !backdrop) return;
		const toggles = document.querySelectorAll('[data-drawer-toggle]');
		const hamburger = document.querySelector('.hamburger');
		const open = () => {
			drawer.classList.add('is-open');
			backdrop.classList.add('is-open');
			document.body.classList.add('drawer-open');
			drawer.setAttribute('aria-hidden', 'false');
			backdrop.setAttribute('aria-hidden', 'false');
			if (hamburger) hamburger.setAttribute('aria-expanded', 'true');
		};
		const close = () => {
			drawer.classList.remove('is-open');
			backdrop.classList.remove('is-open');
			document.body.classList.remove('drawer-open');
			drawer.setAttribute('aria-hidden', 'true');
			backdrop.setAttribute('aria-hidden', 'true');
			if (hamburger) hamburger.setAttribute('aria-expanded', 'false');
		};
		toggles.forEach((t) => t.addEventListener('click', () => {
			drawer.classList.contains('is-open') ? close() : open();
		}));
		backdrop.addEventListener('click', close);
		document.addEventListener('keydown', (e) => {
			if (e.key === 'Escape' && drawer.classList.contains('is-open')) close();
		});
		drawer.querySelectorAll('a').forEach((a) => a.addEventListener('click', close));

		// 子菜单展开/收起
		const subToggle = drawer.querySelector('[data-sub-toggle]');
		const sub = drawer.querySelector('[data-sub]');
		if (subToggle && sub) {
			subToggle.addEventListener('click', (e) => {
				e.stopPropagation();
				const expanded = subToggle.getAttribute('aria-expanded') === 'true';
				subToggle.setAttribute('aria-expanded', expanded ? 'false' : 'true');
				sub.classList.toggle('is-open');
			});
		}
	})();

	/* —— 滚动智能隐藏：下滑藏 / 上滑现 / 贴顶时永远显示 —— */
	(() => {
		if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
		const header = document.querySelector('header');
		if (!header) return;
		const TOP_LOCK = 80;
		const THRESH = 6;
		let lastY = window.scrollY;
		let raf = 0;

		const update = () => {
			const y = window.scrollY;
			const diff = y - lastY;
			if (document.body.classList.contains('drawer-open')) {
				header.classList.remove('is-hidden');
				document.body.classList.remove('header-hidden');
				lastY = y;
				raf = 0;
				return;
			}
			if (Math.abs(diff) < THRESH) {
				raf = 0;
				return;
			}
			if (y < TOP_LOCK) {
				header.classList.remove('is-hidden');
				document.body.classList.remove('header-hidden');
			} else if (diff > 0) {
				header.classList.add('is-hidden');
				document.body.classList.add('header-hidden');
			} else {
				header.classList.remove('is-hidden');
				document.body.classList.remove('header-hidden');
			}
			lastY = y;
			raf = 0;
		};

		window.addEventListener(
			'scroll',
			() => {
				if (!raf) raf = requestAnimationFrame(update);
			},
			{ passive: true },
		);
	})();
</script>

<style>
	header {
		margin: 0;
		padding: 0 1em;
		background: rgba(255, 255, 255, 0.5);
		backdrop-filter: blur(14px) saturate(180%);
		-webkit-backdrop-filter: blur(14px) saturate(180%);
		border-bottom: 1px solid rgba(255, 255, 255, 0.4);
		box-shadow: 0 2px 12px rgba(31, 38, 135, 0.08);
		position: sticky;
		top: 0;
		z-index: 10;
		transition: transform 0.28s cubic-bezier(0.4, 0, 0.2, 1);
		will-change: transform;
	}
	header.is-hidden {
		transform: translateY(-100%);
	}
	@media (prefers-reduced-motion: reduce) {
		header {
			transition: none;
		}
	}
	h2 {
		margin: 0;
		font-size: 1em;
	}

	h2 a,
	h2 a.active {
		text-decoration: none;
	}
	/* 站名是 layout 标识，不是页签——hover 不给反馈。
	   用 nav h2 a 提升选择器特异性，胜过下面的 nav a:hover */
	nav h2 a:hover {
		color: var(--black);
		border-bottom-color: transparent;
		background: transparent;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
	}
	nav a {
		padding: 1em 0.5em;
		color: var(--black);
		border-bottom: 4px solid transparent;
		text-decoration: none;
		transition: color 0.18s ease, border-bottom-color 0.18s ease, background 0.18s ease;
	}
	nav a:hover {
		color: var(--accent);
		border-bottom-color: rgba(35, 55, 255, 0.35);
		background: rgba(35, 55, 255, 0.04);
	}
	nav a.active {
		text-decoration: none;
		border-bottom-color: var(--accent);
	}
	nav a.active:hover {
		border-bottom-color: var(--accent);
	}
	.social-links {
		display: flex;
		gap: 0.45em;
		align-items: center;
	}
	.social-links a {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 40px;
		height: 40px;
		background: rgba(0, 0, 0, 0.04);
		color: rgb(var(--gray));
		text-decoration: none;
		border-radius: 50%;
		transition: background 0.15s ease, color 0.15s ease, transform 0.15s ease;
	}
	.social-links a:hover {
		background: rgba(35, 55, 255, 0.1);
		color: var(--accent);
		transform: translateY(-2px);
	}
	.social-links svg {
		display: block;
		width: 22px;
		height: 22px;
	}

	/* —— 汉堡按钮：默认隐藏，≤720 才出现 —— */
	.hamburger {
		display: none;
		flex-direction: column;
		justify-content: center;
		gap: 5px;
		padding: 1.25em 0.95em;
		margin-right: 0.4em;
		background: transparent;
		border: none;
		cursor: pointer;
		border-radius: 8px;
		transition: background 0.15s ease;
	}
	.hamburger:hover {
		background: rgba(35, 55, 255, 0.06);
	}
	.hb-bar {
		display: block;
		width: 26px;
		height: 2.5px;
		background: rgb(var(--gray-dark));
		border-radius: 2px;
	}

	/* —— 平板：压缩 nav 间距 —— */
	@media (max-width: 960px) {
		header {
			padding: 0 0.6em;
		}
		nav a {
			padding: 1em 0.35em;
		}
		.search-trigger {
			padding: 1em 0.35em;
		}
	}
	/* —— 手机：藏掉社交图标 + 给 header 一个最低高度撑出厚实感 —— */
	@media (max-width: 720px) {
		header {
			min-height: 68px;
		}
		.social-links {
			display: none;
		}
		/* nav 内的链接折到抽屉，搜索按钮独立显示在右侧 */
		.internal-links > a,
		.internal-links .dropdown {
			display: none;
		}
		.hamburger {
			display: inline-flex;
		}
		nav {
			justify-content: space-between;
			min-height: 68px;
		}
		h2 {
			text-align: center;
			flex: 1;
		}
		.internal-links {
			display: flex;
		}
		.search-trigger {
			padding: 1.1em 0.7em;
		}
		.search-trigger svg {
			width: 28px;
			height: 28px;
			stroke-width: 2.2;
		}
	}
	/* —— 超窄屏：藏站名 —— */
	@media (max-width: 480px) {
		header {
			padding: 0 0.4em;
		}
		h2 {
			display: none;
		}
		.search-trigger {
			padding: 1.25em 0.7em;
			font-size: 1em;
		}
	}
	/* —— 二级 dropdown —— */
	.internal-links {
		display: flex;
		align-items: center;
	}
	.dropdown {
		position: relative;
	}
	.dropdown-menu {
		position: absolute;
		top: 100%;
		left: 50%;
		transform: translateX(-50%) translateY(-6px);
		display: flex;
		flex-direction: column;
		min-width: 100px;
		padding: 0.4em 0;
		background: rgba(255, 255, 255, 0.85);
		backdrop-filter: blur(12px) saturate(180%);
		-webkit-backdrop-filter: blur(12px) saturate(180%);
		border: 1px solid rgba(255, 255, 255, 0.5);
		border-radius: 12px;
		box-shadow: 0 8px 24px rgba(31, 38, 135, 0.12);
		opacity: 0;
		pointer-events: none;
		transition:
			opacity 0.18s ease,
			transform 0.18s ease;
		z-index: 20;
	}
	.dropdown-menu a {
		padding: 0.5em 1.2em !important;
		text-align: center;
		border-bottom: none !important;
		white-space: nowrap;
	}
	.dropdown-menu a:hover {
		background: rgba(35, 55, 255, 0.06);
	}
	.dropdown:hover .dropdown-menu,
	.dropdown:focus-within .dropdown-menu {
		opacity: 1;
		pointer-events: auto;
		transform: translateX(-50%) translateY(0);
	}
	/* —— 搜索触发按钮 —— */
	.search-trigger {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 1em 0.5em;
		background: transparent;
		border: none;
		border-bottom: 4px solid transparent;
		font-family: inherit;
		font-size: 1em;
		cursor: pointer;
		color: var(--black);
		transition: background 0.15s ease, color 0.15s ease;
	}
	.search-trigger:hover {
		background: rgba(35, 55, 255, 0.06);
		color: var(--accent);
	}
	.search-trigger svg {
		display: block;
	}

	/* ━━━━━━━━━━ 抽屉 + backdrop ━━━━━━━━━━ */
	.drawer-backdrop {
		position: fixed;
		inset: 0;
		background: rgba(0, 0, 0, 0.4);
		backdrop-filter: blur(4px);
		-webkit-backdrop-filter: blur(4px);
		opacity: 0;
		pointer-events: none;
		transition: opacity 0.25s ease;
		z-index: 90;
	}
	.drawer-backdrop.is-open {
		opacity: 1;
		pointer-events: auto;
	}
	.drawer {
		position: fixed;
		top: 0;
		left: 0;
		bottom: 0;
		width: min(280px, 80vw);
		background: rgba(255, 255, 255, 0.92);
