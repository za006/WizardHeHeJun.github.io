---
import { getCollection } from 'astro:content';
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';

// 最近文章 ticker（仅 ≤640 显示，自动滚动）
const allPosts = await getCollection('blog');
const recent = allPosts
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 5);
// 末尾补一份首项实现无缝循环
const tickerItems = recent.length > 0 ? [...recent, recent[0]] : [];
---

<header>
	<nav>
		<button
			type="button"
			class="hamburger"
			data-drawer-toggle
			aria-label="打开菜单"
			aria-expanded="false"
			aria-controls="mobile-drawer"
		>
			<span class="hb-bar"></span>
			<span class="hb-bar"></span>
			<span class="hb-bar"></span>
		</button>

		<h2><a href="/">{SITE_TITLE}</a></h2>
		{
			tickerItems.length > 1 && (
				<div class="ticker" aria-label="最近文章">
					<span class="ticker-dot" aria-hidden="true"></span>
					<div class="ticker-window">
						<ul class="ticker-list" style={`--ticker-count: ${recent.length}`}>
							{tickerItems.map((p) => (
								<li>
									<a href={`/blog/${p.id}/`}>{p.data.title}</a>
								</li>
							))}
						</ul>
					</div>
				</div>
			)
		}
		<div class="internal-links">
			<HeaderLink href="/">首页</HeaderLink>
			<div class="dropdown">
				<HeaderLink href="/blog">博客 ▾</HeaderLink>
				<div class="dropdown-menu" role="menu">
					<HeaderLink href="/categories">分类</HeaderLink>
					<HeaderLink href="/tags">标签</HeaderLink>
				</div>
			</div>
			<HeaderLink href="/memories">回忆</HeaderLink>
			<HeaderLink href="/whiteboard">画板</HeaderLink>
			<HeaderLink href="/friends">友链</HeaderLink>
			<HeaderLink href="/about">关于</HeaderLink>
			<button type="button" class="search-trigger" data-search-trigger aria-label="打开搜索">
				<svg viewBox="0 0 24 24" aria-hidden="true" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
					><circle cx="11" cy="11" r="7"></circle><path d="m20 20-3.5-3.5"></path></svg
				>
			</button>
		</div>
		<div class="social-links">
			<a href="https://github.com/WizardHeHeJun" target="_blank" rel="noopener" aria-label="GitHub">
