---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Comments from '../components/Comments.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import HeroImage from '../components/HeroImage.astro';
import TableOfContents from '../components/TableOfContents.astro';

type PostRef = { id: string; title: string } | null;
type Props = CollectionEntry<'blog'>['data'] & {
	slug?: string;
	wordCount?: number;
	readingTime?: number;
	prevPost?: PostRef;
	nextPost?: PostRef;
};

const {
	slug,
	title,
	description,
	pubDate,
	updatedDate,
	heroImage,
	category,
	tags = [],
	wordCount,
	readingTime,
	prevPost = null,
	nextPost = null,
} = Astro.props;
---

<html lang="zh-CN">
	<head>
		<BaseHead title={title} description={description} />
		<style>
			main {
				width: 100%;
				max-width: 100%;
				margin: 0;
				padding: 2em 1em;
				background: transparent;
				backdrop-filter: none;
				-webkit-backdrop-filter: none;
				border: none;
				border-radius: 0;
				box-shadow: none;
			}
			.hero-image {
				width: min(1100px, 100% - 2em);
				margin: 0 auto 1em;
				aspect-ratio: 1020 / 510;
				border-radius: 16px;
				overflow: hidden;
				box-shadow: 0 8px 32px rgba(31, 38, 135, 0.2);
			}
			.hero-image img {
				display: block;
				margin: 0 auto;
			}
			.prose {
				width: min(840px, 100% - 2em);
				margin: auto;
				padding: 2.5em 2.4em;
				color: rgb(var(--gray-dark));
				background: rgba(255, 255, 255, 0.6);
				backdrop-filter: blur(18px) saturate(180%);
				-webkit-backdrop-filter: blur(18px) saturate(180%);
				border: 1px solid rgba(255, 255, 255, 0.45);
				border-radius: 18px;
				box-shadow: 0 8px 32px rgba(31, 38, 135, 0.15);
			}
			@media (min-width: 1400px) {
				.hero-image {
					width: min(1280px, 100% - 4em);
				}
				.prose {
					width: min(960px, 100% - 4em);
					padding: 3em 3em;
				}
			}
			@media (min-width: 1800px) {
				.hero-image {
					width: min(1440px, 100% - 6em);
				}
				.prose {
					width: min(1100px, 100% - 6em);
					padding: 3em 3.5em;
				}
			}
			@media (max-width: 640px) {
				.prose {
					padding: 1.6em 1.2em;
				}
			}
			.comments-wrap {
				width: min(840px, 100% - 2em);
				margin: 2em auto 0;
			}
			@media (min-width: 1400px) {
				.comments-wrap {
					width: min(960px, 100% - 4em);
				}
			}
			@media (min-width: 1800px) {
				.comments-wrap {
					width: min(1100px, 100% - 6em);
				}
			}
			.title {
				margin-bottom: 1em;
				padding: 0.5em 0 1em;
				text-align: center;
				line-height: 1;
			}
			.title h1 {
				margin: 0 0 0.5em 0;
			}
			.date {
				margin-bottom: 0.5em;
				color: rgb(var(--gray));
			}
			.last-updated-on {
				font-style: italic;
			}
			.stats {
				font-size: 0.9em;
				color: rgb(var(--gray));
			}
			.meta-row {
				display: flex;
				flex-wrap: wrap;
				gap: 0.6em;
				justify-content: center;
				margin-top: 0.6em;
			}
			.meta-row a {
				display: inline-block;
				padding: 0.15em 0.7em;
				background: rgba(35, 55, 255, 0.08);
				border: 1px solid rgba(35, 55, 255, 0.18);
				border-radius: 999px;
				font-size: 0.85em;
				color: var(--accent);
				text-decoration: none;
				transition: background 0.15s ease;
			}
			.meta-row a:hover {
				background: rgba(35, 55, 255, 0.16);
			}
			.meta-row .cat {
				background: rgba(255, 200, 100, 0.25);
				border-color: rgba(255, 180, 80, 0.5);
				color: #b8860b;
				font-weight: 600;
			}
			.meta-row .cat:hover {
				background: rgba(255, 200, 100, 0.45);
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				<div class="hero-image">
					{heroImage && slug && (
						<HeroImage slug={slug} src={heroImage} width={1020} height={510} loading="eager" />
					)}
				</div>
				<TableOfContents prevPost={prevPost} nextPost={nextPost} />
				<div class="prose" data-pagefind-body>
					<div class="title">
						<div class="date">
							<FormattedDate date={pubDate} />
							{wordCount !== undefined && readingTime !== undefined && (
								<span class="stats"> · {wordCount} 字 · {readingTime} 分钟阅读</span>
							)}
							{
								updatedDate && (
									<div class="last-updated-on">
										最后更新于 <FormattedDate date={updatedDate} />
									</div>
								)
							}
						</div>
						<h1>{title}</h1>
						{
							(category || tags.length > 0) && (
								<div class="meta-row">
									{category && (
										<a class="cat" href={`/categories/${encodeURIComponent(category)}/`}>
											{category}
										</a>
									)}
									{tags.map((t) => (
										<a href={`/tags/${encodeURIComponent(t)}/`}>#{t}</a>
									))}
								</div>
							)
						}
						<hr />
					</div>
					<slot />
				</div>
			</article>
			<div class="comments-wrap">
				<Comments mapping="pathname" />
			</div>
		</main>
		<Footer />

		<script is:inline>
			(function () {
				function initSpoilers() {
					document.querySelectorAll('.prose .spoiler').forEach((el) => {
						el.addEventListener('click', () => el.classList.add('revealed'));
						el.addEventListener('keydown', (e) => {
							if (e.key === 'Enter' || e.key === ' ') {
								e.preventDefault();
								el.classList.add('revealed');
							}
						});
					});
				}
				if (document.readyState === 'loading') {
					document.addEventListener('DOMContentLoaded', initSpoilers);
				} else {
					initSpoilers();
				}
			})();
		</script>

		<script>
			// Mermaid lazy load —— 仅当本文有 .mermaid 块时才载 mermaid.js（~700KB）
			if (document.querySelector('.prose .mermaid')) {
				import('mermaid').then(({ default: mermaid }) => {
					mermaid.initialize({
						startOnLoad: false,
						theme: 'base',
						themeVariables: {
							fontFamily: "'LXGW WenKai Screen', 'PingFang SC', sans-serif",
							primaryColor: '#dde7ff',
							primaryTextColor: '#222939',
							primaryBorderColor: '#2337ff',
							lineColor: '#66ccff',
							secondaryColor: '#ffd1e4',
							tertiaryColor: '#f0f6ff',
							noteBkgColor: '#fff7e6',
							noteBorderColor: '#b8860b',
						},
					});
					mermaid.run({ querySelector: '.prose .mermaid' });
				});
			}
		</script>
	</body>
</html>
